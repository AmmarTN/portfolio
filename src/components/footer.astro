---
import { portfolio } from "@/data/portfolio";
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div class="space-y-2">
        <p class="text-lg font-medium text-[var(--white)]">
          {portfolio.profile.name}
        </p>
        <p class="max-w-2xl text-sm leading-6 text-[var(--white-icon)]">
          Flutter-first portfolio focused on polished mobile products, clean
          architecture, and dependable delivery.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        {
          portfolio.profile.socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-[var(--white-icon)] transition duration-300 hover:text-[var(--white)]"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-[#ffffff10]">
      <div class="flex flex-col gap-2 text-sm text-[var(--white-icon)] md:flex-row md:items-center md:justify-between">
        <p class="w-full text-center">Copyright © {currentYear} Ahmed Ammar. All rights reserved.</p>
        
      </div>
    </div>
  </div>
</footer>
