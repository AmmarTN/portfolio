---
import { portfolio } from "@/data/portfolio";
---

<section
  id="about"
  class="py-12 border-t border-[var(--white-icon-tr)] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto space-y-8 md:space-y-10">
    <div class="max-w-3xl space-y-3">
      <h2 class="text-lg text-[var(--sec)] shiny-sec">Why I build this way</h2>
      <h3 class="text-4xl md:text-5xl font-medium">About</h3>
      <p class="text-[var(--white-icon)] text-base md:text-lg">
        The product instincts, engineering priorities, and delivery habits that
        shape how I work.
      </p>
    </div>

    <div class="grid items-start gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="relative overflow-hidden rounded-[2rem] border border-[var(--white-icon-tr)] bg-[radial-gradient(circle_at_top,_rgba(164,118,255,0.18),_rgba(11,11,12,0.98)_48%)] shadow-[0_32px_90px_-64px_rgba(164,118,255,0.55)]">
        <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.05),transparent_38%,transparent)]"></div>
        <div class="absolute -right-20 top-10 h-56 w-56 rounded-full bg-[rgba(164,118,255,0.12)] blur-3xl"></div>
        <div class="absolute -left-14 bottom-0 h-44 w-44 rounded-full bg-[rgba(255,255,255,0.06)] blur-3xl"></div>

        <div class="relative flex min-h-[31rem] flex-col justify-between p-6 md:p-8">
          <div class="space-y-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="space-y-2">
                <p class="text-xs uppercase tracking-[0.26em] text-[var(--sec)]">
                  {portfolio.profile.name}
                </p>
                <p class="text-sm text-[var(--white-icon)]">
                  {portfolio.profile.role} • {portfolio.profile.location}
                </p>
              </div>

              <span class="rounded-full border border-[var(--white-icon-tr)] bg-[#121214] px-3 py-1 text-xs uppercase tracking-[0.18em] text-[var(--white-icon)]">
                Open to mobile product work
              </span>
            </div>

            <div class="inline-flex h-24 w-24 items-center justify-center rounded-[2rem] border border-[var(--white-icon-tr)] bg-[#141416c7] text-4xl font-semibold text-[var(--white)] shadow-[0_18px_50px_-30px_rgba(164,118,255,0.45)]">
              AA
            </div>

            <div class="space-y-3">
              <p class="text-3xl font-semibold leading-tight text-[var(--white)] md:text-[2.6rem]">
                Flutter engineer for polished mobile products.
              </p>
              <p class="max-w-md text-sm leading-7 text-[var(--white-icon)] md:text-base">
                Strong on product feel, architecture discipline, and the release work that keeps apps dependable after launch.
              </p>
            </div>
          </div>

          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              {
                portfolio.about.visualHighlights.map((line) => (
                  <span class="whitespace-nowrap rounded-full border border-[var(--white-icon-tr)] bg-[#131314c7] px-3.5 py-1.5 text-sm font-medium text-[var(--white-icon)]">
                    {line}
                  </span>
                ))
              }
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              {
                portfolio.profile.proofPoints.slice(0, 4).map((point) => (
                  <div class="rounded-2xl border border-[var(--white-icon-tr)] bg-[#131314c7] px-4 py-4 text-sm leading-6 text-[var(--white-icon)] backdrop-blur-sm">
                    {point}
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-6 md:space-y-7 lg:pt-2">
        <div class="space-y-4">
          <h3 class="max-w-2xl text-[clamp(2.5rem,5vw,4.5rem)] font-medium leading-[0.98]">
            <span class="text-[var(--sec)]">{portfolio.about.headingAccent}</span>{" "}
            {portfolio.about.heading}
          </h3>
          <p class="max-w-2xl text-[var(--white-icon)] text-base leading-8 md:text-lg">
            {portfolio.about.lead}
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {
            portfolio.about.principles.map((principle, index) => (
              <article class="rounded-2xl border border-[var(--white-icon-tr)] bg-[var(--component-bg)] p-5">
                <div class="flex items-start gap-3">
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[var(--white-icon-tr)] bg-[#141414] text-xs font-medium text-[var(--sec)]">
                    0{index + 1}
                  </span>
                  <p class="pt-0.5 text-base font-medium leading-6 text-[var(--white)]">
                    {principle.title}
                  </p>
                </div>
                <p class="mt-4 text-sm leading-7 text-[var(--white-icon)]">
                  {principle.body}
                </p>
              </article>
            ))
          }
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          {
            portfolio.about.stats.map((stat) => (
              <article class="rounded-2xl border border-[var(--white-icon-tr)] bg-[linear-gradient(180deg,rgba(164,118,255,0.08),rgba(18,18,20,0.94))] px-5 py-6 text-center">
                <p class="text-4xl font-semibold text-[var(--white)] md:text-[2.6rem]">
                  {stat.value}
                </p>
                <p class="mt-3 text-sm leading-6 text-[var(--white-icon)]">
                  {stat.label}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
